# ============ DATABASE (Supabase) ============
# Supabase Dashboard > Project Settings > Database > Connection string
#
# DATABASE_URL: "Transaction" pooler (port 6543) - uygulama runtime'ı için.
#   pgbouncer=true parametresini eklemeyi unutma.
# DIRECT_URL: "Session" / direct connection (port 5432) - sadece
#   `prisma migrate` çalıştırırken kullanılır (pooler migration'ı desteklemez).
DATABASE_URL="postgresql://postgres.xxxxxxxxxxxx:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxxxxxxxxxx:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"

# ============ REDIS (Railway eklentisi / BullMQ) ============
# Railway'de Redis servisi eklediğinde "REDIS_URL" değişkenini otomatik verir.
# Aşağıdaki host/port/password'u Railway'in verdiği bağlantı bilgisinden doldur
# (Railway Redis genelde tek bir REDIS_URL verir, gerekirse parse ederiz).
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ============ JWT ============
JWT_SECRET=degistir-bunu-guclu-bir-sifre
JWT_EXPIRES_IN=7d

# ============ YouTube Data API v3 ============
YOUTUBE_API_KEY=your_youtube_api_key_here
YOUTUBE_CHANNEL_ID=UCxxxxxxxxxxxxxxxxxxxxxx
YOUTUBE_SYNC_CRON="*/15 * * * *"

# ============ Claude API ============
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6

# ============ Haber senkron ============
NEWS_SYNC_CRON="*/30 * * * *"
NEWS_AUTO_PUBLISH=false

# ============ CORS ============
# Netlify'a deploy ettiğin frontend domaini (virgülle birden fazla eklenebilir)
FRONTEND_URL=https://ege-tv.netlify.app,http://localhost:3000

# ============ Rate Limiting (Throttler) ============
THROTTLE_TTL=60
THROTTLE_LIMIT=60

# ============ YouTube API Quota ============
YOUTUBE_QUOTA_DAILY_LIMIT=10000
YOUTUBE_QUOTA_WARN_PCT=80

# Railway bu değişkeni otomatik enjekte eder, lokal geliştirmede sen ver
PORT=3001
